# ═══════════════════════════════════════════════════
# Cloud Run Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file and fill in your actual values.
# DO NOT commit the filled version to git.
#
# Usage: gcloud run deploy ... --env-vars-file .env.cloudrun.yaml
# ═══════════════════════════════════════════════════

# Firebase (Public — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY: "YOUR_VALUE"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN: "talent-consulting-acf16.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID: "talent-consulting-acf16"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET: "talent-consulting-acf16.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID: "YOUR_VALUE"
NEXT_PUBLIC_FIREBASE_APP_ID: "YOUR_VALUE"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID: "YOUR_VALUE"

# AI Services (Server-side secrets)
GROQ_API_KEY: "YOUR_VALUE"
GEMINI_API_KEY: "YOUR_VALUE"
OPENROUTER_API_KEY: "YOUR_VALUE"
DEEPGRAM_API_KEY: "YOUR_VALUE"

# DashScope
DASHSCOPE_API_KEY: "YOUR_VALUE"
DASHSCOPE_TTS_MODEL: "cosyvoice-v3-flash"
DASHSCOPE_WS_URL: "wss://dashscope-intl.aliyuncs.com/api-ws/v1/inference"

# Stripe (Production)
STRIPE_SECRET_KEY: "YOUR_VALUE"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: "YOUR_VALUE"
STRIPE_WEBHOOK_SECRET: "YOUR_VALUE"
STRIPE_PRO_PRICE_ID: "YOUR_VALUE"
STRIPE_PRO_ANNUAL_PRICE_ID: "YOUR_VALUE"
STRIPE_STUDIO_PRICE_ID: "YOUR_VALUE"
STRIPE_STUDIO_ANNUAL_PRICE_ID: "YOUR_VALUE"

# Jobs
ADZUNA_APP_ID: "YOUR_VALUE"
ADZUNA_API_KEY: "YOUR_VALUE"

# Email
RESEND_API_KEY: "YOUR_VALUE"

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_JSON: 'YOUR_JSON_STRING'

# Discord Monitoring
DISCORD_WEBHOOK_URL: "YOUR_VALUE"
DISCORD_WEBHOOK_CRITICAL: "YOUR_VALUE"
DISCORD_WEBHOOK_BUSINESS: "YOUR_VALUE"
